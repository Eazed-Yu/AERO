# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DATABASE=aero

# MCP Server
ENABLE_MCP=true
MCP_SERVER_NAME=aero-energy
MCP_BASE_PATH=/mcp
# Optional public URL override for reverse proxies, e.g. https://aero.example.com
MCP_PUBLIC_BASE_URL=

# LLM Provider: "ollama" or "api"
LLM_PROVIDER=api

# Ollama (本地)
OLLAMA_HOST=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:3b
OLLAMA_EMBEDDING_MODEL=bge-m3:latest
OLLAMA_EMBEDDING_DIM=1024

# API (OpenAI 兼容)
LLM_API_KEY=sk-your-api-key
LLM_API_BASE=https://api.siliconflow.cn/v1
LLM_MODEL_NAME=deepseek-ai/DeepSeek-V3
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024

# ========================================
# LightRAG Web UI Server (可选)
# ========================================
ENABLE_LIGHTRAG_SERVER=false

# 启用后配置以下选项：
LIGHTRAG_SERVER_PORT=8030
LIGHTRAG_SERVER_HOST=127.0.0.1

# LightRAG LLM 配置
# 选项: openai, ollama, azure_openai, gemini
LIGHTRAG_LLM_BINDING=openai
LIGHTRAG_LLM_MODEL=deepseek-ai/DeepSeek-V3
# 留空使用上面的 LLM_API_BASE 或 OLLAMA_HOST
# 或自定义: http://localhost:11434, https://api.openai.com/v1
LIGHTRAG_LLM_HOST=

# LightRAG Embedding 配置
LIGHTRAG_EMBEDDING_BINDING=openai
LIGHTRAG_EMBEDDING_MODEL=text-embedding-v3
LIGHTRAG_EMBEDDING_DIM=1024
LIGHTRAG_EMBEDDING_HOST=

# ========================================
# 配置示例
# ========================================

# 示例1: 使用阿里云 Dashscope
# ENABLE_LIGHTRAG_SERVER=true
# LIGHTRAG_LLM_BINDING=openai
# LIGHTRAG_LLM_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
# LIGHTRAG_LLM_MODEL=deepseek-ai/DeepSeek-V3
# LIGHTRAG_EMBEDDING_BINDING=openai
# LIGHTRAG_EMBEDDING_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
# LIGHTRAG_EMBEDDING_MODEL=text-embedding-v3

# 示例2: 使用本地 Ollama
# ENABLE_LIGHTRAG_SERVER=true
# LIGHTRAG_LLM_BINDING=ollama
# LIGHTRAG_LLM_HOST=http://localhost:11434
# LIGHTRAG_LLM_MODEL=qwen2.5:7b
# LIGHTRAG_EMBEDDING_BINDING=ollama
# LIGHTRAG_EMBEDDING_HOST=http://localhost:11434
# LIGHTRAG_EMBEDDING_MODEL=bge-m3:latest

# 示例3: 混合配置（Ollama LLM + API Embedding）
# ENABLE_LIGHTRAG_SERVER=true
# LIGHTRAG_LLM_BINDING=ollama
# LIGHTRAG_LLM_HOST=http://localhost:11434
# LIGHTRAG_LLM_MODEL=qwen2.5:7b
# LIGHTRAG_EMBEDDING_BINDING=openai
# LIGHTRAG_EMBEDDING_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
# LIGHTRAG_EMBEDDING_MODEL=text-embedding-v3

# 示例4: 自定义 OpenAI 兼容 API
# ENABLE_LIGHTRAG_SERVER=true
# LIGHTRAG_LLM_BINDING=openai
# LIGHTRAG_LLM_HOST=http://your-custom-api:8000/v1
# LIGHTRAG_LLM_MODEL=your-model
# LIGHTRAG_EMBEDDING_BINDING=openai
# LIGHTRAG_EMBEDDING_HOST=http://your-custom-api:8000/v1
# LIGHTRAG_EMBEDDING_MODEL=your-embedding-model
