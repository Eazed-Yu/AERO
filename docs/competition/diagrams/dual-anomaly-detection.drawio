  <diagram name="双层异常检测架构" id="dual-anomaly-detection">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="双层异常检测架构流程图" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontStyle=1;fontSize=16;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="380" y="15" width="400" height="35" as="geometry" />
        </mxCell>

        <!-- 输入 -->
        <mxCell id="input" value="多传感器能耗时序数据&#xa;(electricity, water, gas, hvac,&#xa;supply_temp, return_temp,&#xa;flow_rate, outdoor_temp)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontStyle=1;fontSize=11;shadow=1;" vertex="1" parent="1">
