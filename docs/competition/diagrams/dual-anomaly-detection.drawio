          <mxGeometry x="40" y="270" width="440" height="280" as="geometry" />
        </mxCell>
        <mxCell id="layer1-title" value="第一层：阈值检测器 (ThresholdDetector)" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=#2E7D32;fontStyle=1;fontSize=12;fontColor=#FFFFFF;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="280" width="400" height="30" as="geometry" />
