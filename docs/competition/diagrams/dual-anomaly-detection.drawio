        <mxCell id="season" value="季节自适应逻辑：&#xa;制冷（外温&gt;22℃）→ 期望7℃&#xa;制热（外温≤22℃）→ 期望45℃" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontSize=9;fontStyle=2;" vertex="1" parent="1">
