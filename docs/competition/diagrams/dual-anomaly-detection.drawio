        <mxCell id="layer1-speed" value="响应时间 &lt; 10ms" style="text;html=1;align=center;strokeColor=none;fillColor=none;fontSize=10;fontColor=#2E7D32;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="280" y="310" width="120" height="20" as="geometry" />
        </mxCell>

        <mxCell id="t1" value="能耗突增检测&#xa;(energy_spike)&#xa;当前值 &gt; 均值 × 2.0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="340" width="180" height="60" as="geometry" />
