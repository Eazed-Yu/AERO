        <mxCell id="t2" value="COP异常检测&#xa;(low_cop)&#xa;COP &lt; 2.0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="415" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="温度偏差检测&#xa;(temp_deviation)&#xa;|供水温度 - 期望值| &gt; 5℃" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;" vertex="1" parent="1">
