                <mxCell id="step1" value="1. &quot;A栋楼上周的电力消耗是多少？&quot;" style="text;html=1;align=center;strokeColor=none;fillColor=#E3F2FD;fontSize=12;fontStyle=1;rounded=1;" parent="1" vertex="1">
