<mxfile host="app.diagrams.net" modified="2026-03-10T00:00:00.000Z" agent="AERO" version="24.0.0" type="device">
  <diagram name="MCP协议交互流程" id="mcp-interaction-flow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="MCP协议交互流程 — 自然语言驱动的能耗数据查询" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontStyle=1;fontSize=16;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="250" y="15" width="600" height="35" as="geometry" />
        </mxCell>

        <!-- 角色 -->
        <mxCell id="user" value="运维人员" style="shape=mxgraph.basic.smiley;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="user-label" value="运维人员" style="text;html=1;align=center;strokeColor=none;fillColor=none;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="145" width="80" height="20" as="geometry" />
        </mxCell>

        <mxCell id="ai-client" value="Claude Desktop&#xa;（MCP Client）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontStyle=1;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="80" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="mcp-server" value="AERO MCP Server&#xa;（FastMCP）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontStyle=1;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="80" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="backend" value="FastAPI&#xa;Service Layer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;fontStyle=1;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="940" y="80" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- 时序线 -->
        <mxCell id="line-user" value="" style="endArrow=none;dashed=1;strokeColor=#1565C0;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="90" y="170" as="sourcePoint" /><mxPoint x="90" y="720" as="targetPoint" /></mxGeometry>
        </mxCell>
        <mxCell id="line-ai" value="" style="endArrow=none;dashed=1;strokeColor=#2E7D32;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="390" y="145" as="sourcePoint" /><mxPoint x="390" y="720" as="targetPoint" /></mxGeometry>
        </mxCell>
        <mxCell id="line-mcp" value="" style="endArrow=none;dashed=1;strokeColor=#E65100;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="710" y="145" as="sourcePoint" /><mxPoint x="710" y="720" as="targetPoint" /></mxGeometry>
        </mxCell>
        <mxCell id="line-backend" value="" style="endArrow=none;dashed=1;strokeColor=#6A1B9A;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1020" y="145" as="sourcePoint" /><mxPoint x="1020" y="720" as="targetPoint" /></mxGeometry>
        </mxCell>

        <!-- Step 1: 用户提问 -->
        <mxCell id="step1" value="1. &quot;A栋楼上周的电力消耗是多少？&quot;" style="text;html=1;align=center;strokeColor=none;fillColor=#E3F2FD;fontSize=10;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="190" width="270" height="25" as="geometry" />
        </mxCell>
        <mxCell id="a1" style="endArrow=block;strokeColor=#1565C0;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="95" y="200" as="sourcePoint" /><mxPoint x="385" y="200" as="targetPoint" /></mxGeometry>
        </mxCell>

        <!-- Step 2: 意图识别 -->
        <mxCell id="step2" value="2. LLM意图识别 → 选择MCP工具&#xa;工具: query_energy_data&#xa;参数: {building_id: &quot;BLD-001&quot;, &#xa;       start_date: &quot;2026-03-03&quot;,&#xa;       end_date: &quot;2026-03-09&quot;,&#xa;       metrics: [&quot;electricity_kwh&quot;]}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=9;align=left;" vertex="1" parent="1">
          <mxGeometry x="305" y="230" width="250" height="100" as="geometry" />
        </mxCell>

        <!-- Step 3: MCP调用 -->
        <mxCell id="step3" value="3. JSON-RPC 2.0 请求（Streamable HTTP）" style="text;html=1;align=center;strokeColor=none;fillColor=#FFF3E0;fontSize=10;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="350" width="270" height="25" as="geometry" />
        </mxCell>
        <mxCell id="a3" style="endArrow=block;strokeColor=#E65100;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="395" y="360" as="sourcePoint" /><mxPoint x="705" y="360" as="targetPoint" /></mxGeometry>
        </mxCell>

        <!-- Step 4: 调用服务 -->
        <mxCell id="step4" value="4. 工具函数执行 → 调用EnergyService" style="text;html=1;align=center;strokeColor=none;fillColor=#FFF3E0;fontSize=10;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="730" y="390" width="270" height="25" as="geometry" />
        </mxCell>
        <mxCell id="a4" style="endArrow=block;strokeColor=#6A1B9A;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="715" y="400" as="sourcePoint" /><mxPoint x="1015" y="400" as="targetPoint" /></mxGeometry>
        </mxCell>

        <!-- Step 5: 数据库查询 -->
        <mxCell id="step5" value="5. PostgreSQL 查询&#xa;SELECT ... FROM energy_records&#xa;WHERE building_id = 'BLD-001'&#xa;AND timestamp BETWEEN ..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;fontSize=9;align=left;" vertex="1" parent="1">
          <mxGeometry x="935" y="430" width="210" height="70" as="geometry" />
        </mxCell>

        <!-- Step 6: 返回数据 -->
        <mxCell id="a6" style="endArrow=block;strokeColor=#6A1B9A;strokeWidth=2;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1015" y="520" as="sourcePoint" /><mxPoint x="715" y="520" as="targetPoint" /></mxGeometry>
        </mxCell>
        <mxCell id="step6" value="6. 返回结构化能耗数据" style="text;html=1;align=center;strokeColor=none;fillColor=#F3E5F5;fontSize=10;fontStyle=2;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="510" width="250" height="20" as="geometry" />
        </mxCell>

        <!-- Step 7: MCP返回 -->
        <mxCell id="a7" style="endArrow=block;strokeColor=#E65100;strokeWidth=2;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="705" y="560" as="sourcePoint" /><mxPoint x="395" y="560" as="targetPoint" /></mxGeometry>
        </mxCell>
        <mxCell id="step7" value="7. MCP Tool Result（JSON格式）" style="text;html=1;align=center;strokeColor=none;fillColor=#FFF3E0;fontSize=10;fontStyle=2;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="550" width="260" height="20" as="geometry" />
        </mxCell>

        <!-- Step 8: LLM生成回答 -->
        <mxCell id="step8" value="8. LLM根据数据生成自然语言回答：&#xa;&quot;A栋大楼（绿地办公大厦）上周（3月3日-9日）&#xa;的电力总消耗为 12,458.6 kWh，&#xa;日均 1,779.8 kWh，&#xa;峰值出现在周三（2,156.3 kWh）。&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=9;align=left;" vertex="1" parent="1">
          <mxGeometry x="305" y="590" width="250" height="90" as="geometry" />
        </mxCell>

        <!-- Step 9: 回答用户 -->
        <mxCell id="a9" style="endArrow=block;strokeColor=#1565C0;strokeWidth=2;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="385" y="700" as="sourcePoint" /><mxPoint x="95" y="700" as="targetPoint" /></mxGeometry>
        </mxCell>
        <mxCell id="step9" value="9. 自然语言回答" style="text;html=1;align=center;strokeColor=none;fillColor=#E3F2FD;fontSize=10;fontStyle=2;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="130" y="690" width="230" height="20" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
