  <diagram name="异常检测算法架构" id="anomaly-detection">
    <mxGraphModel dx="1400" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="异常检测算法架构（策略模式 + 时间序列扩展）" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontStyle=1;fontSize=16;fontColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="380" y="20" width="380" height="30" as="geometry" />
        </mxCell>

        <!-- 数据输入 -->
        <mxCell id="input-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;dashed=0;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="300" height="200" as="geometry" />
        </mxCell>
        <mxCell id="input-label" value="数据输入" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontStyle=1;fontSize=13;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="55" y="78" width="70" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ts-data" value="时间序列能耗数据&#xa;&#xa;· electricity_kwh（电力）&#xa;· hvac_kwh（暖通）&#xa;· hvac_supply_temp（供水温度）&#xa;· hvac_return_temp（回水温度）&#xa;· outdoor_temp（室外温度）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="55" y="110" width="270" height="140" as="geometry" />
        </mxCell>

        <!-- 编排层: AnomalyService -->
        <mxCell id="svc" value="AnomalyService（编排层）&#xa;&#xa;1. 查询 energy_records&#xa;2. 构造 DetectionContext&#xa;3. 分发给 Detector&#xa;4. 持久化 AnomalyEvent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=11;fontStyle=0;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="100" width="230" height="110" as="geometry" />
        </mxCell>

        <!-- 策略模式 -->
        <mxCell id="abstract" value="AbstractDetector (ABC)&#xa;detect(records, context) → list[dict]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="270" width="280" height="50" as="geometry" />
        </mxCell>

        <!-- 策略1: 阈值检测 -->
        <mxCell id="threshold-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;dashed=0;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="360" height="260" as="geometry" />
        </mxCell>
        <mxCell id="threshold-label" value="策略一：ThresholdDetector（已实现）" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontStyle=1;fontSize=12;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="55" y="388" width="260" height="25" as="geometry" />
        </mxCell>
        <mxCell id="th-spike" value="电力尖峰检测&#xa;&#xa;electricity_kwh > mean × spike_factor&#xa;severity 按超出倍数分级" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="55" y="425" width="220" height="65" as="geometry" />
        </mxCell>
        <mxCell id="th-cop" value="COP 低值检测&#xa;&#xa;COP &lt; min_cop（默认 2.0）&#xa;标识暖通系统效率异常" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="55" y="500" width="220" height="65" as="geometry" />
        </mxCell>
        <mxCell id="th-temp" value="温度偏差检测&#xa;&#xa;|supply_temp - expected| > deviation&#xa;默认阈值 5°C" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="55" y="575" width="220" height="55" as="geometry" />
        </mxCell>

        <!-- 策略2: 时间序列异常检测 (师兄方向) -->
        <mxCell id="ml-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;dashed=0;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="450" y="380" width="500" height="340" as="geometry" />
        </mxCell>
        <mxCell id="ml-label" value="策略二：时间序列异常检测（扩展方向）" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontStyle=1;fontSize=12;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="465" y="388" width="300" height="25" as="geometry" />
        </mxCell>

        <mxCell id="ml-preprocess" value="数据预处理&#xa;&#xa;· 缺失值插补&#xa;· 时间窗口滑动切片&#xa;· 多变量特征对齐" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="470" y="425" width="180" height="85" as="geometry" />
        </mxCell>
        <mxCell id="ml-model" value="异常检测模型&#xa;&#xa;· 基于结构感知路由的&#xa;  工业多传感器时间序列&#xa;  异常检测（SAR-AD）&#xa;&#xa;【占位：师兄论文方法详述】" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="680" y="425" width="250" height="115" as="geometry" />
        </mxCell>
        <mxCell id="ml-score" value="异常评分&#xa;&#xa;· 重构误差 → 异常分数&#xa;· 动态阈值自适应&#xa;· 多粒度评分融合" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="470" y="530" width="180" height="85" as="geometry" />
        </mxCell>
        <mxCell id="ml-diag" value="根因诊断&#xa;&#xa;· 异常传感器定位&#xa;· 故障类型分类&#xa;· 关联 LLM 解释生成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="680" y="560" width="250" height="85" as="geometry" />
        </mxCell>

        <mxCell id="ml-ref" value="理论支撑：A structure-aware routing based anomaly detection&#xa;for industrial multi-sensor time series.&#xa;Engineering Applications of Artificial Intelligence, 2025.（JCR Q1，中科院1区）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#81C784;fontSize=9;fontStyle=2;align=left;spacingLeft=8;" vertex="1" parent="1">
