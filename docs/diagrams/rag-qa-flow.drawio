        <mxCell id="chunk" value="文档分块&#xa;&#xa;DocumentProcessor&#xa;自动分割文本块" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="130" width="160" height="70" as="geometry" />
