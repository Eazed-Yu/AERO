        <mxCell id="llm-gen" value="LLM 生成回答&#xa;&#xa;Qwen2.5-7B-Instruct&#xa;（via SiliconFlow API）&#xa;&#xa;基于检索上下文&#xa;生成专业回答" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;fontStyle=0;" vertex="1" parent="1">
