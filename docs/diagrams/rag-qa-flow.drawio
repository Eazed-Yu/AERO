        <mxCell id="online-label" value="在线阶段：检索增强生成（RAG）" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontStyle=1;fontSize=13;fontColor=#4527A0;" vertex="1" parent="1">
