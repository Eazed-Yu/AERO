        <!-- Title -->
        <mxCell id="title" value="基于 LightRAG 知识图谱的智能问答流程" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontStyle=1;fontSize=16;fontColor=#4527A0;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="320" height="30" as="geometry" />
        </mxCell>

        <!-- Step 1: 知识库构建（离线） -->
