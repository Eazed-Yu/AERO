        <mxCell id="retrieve" value="知识检索&#xa;&#xa;向量相似度匹配&#xa;+&#xa;图谱关系遍历&#xa;&#xa;返回相关文档片段" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=10;" vertex="1" parent="1">
