        <mxCell id="mode-naive" value="naive 模式&#xa;朴素向量检索" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="530" y="490" width="150" height="45" as="geometry" />
